{
    "jsonguide": {
            "id": "is unique for each item",
            "type": "either building(placeable in building layer), wire(placeable in wire layer), or material(not placeable but can be transferred in conveyors, crafted, interact via input/outputs/mined)",
            "input": "(building or wire only)0 for does not have input, 1 for can be inputted into",
            "output":"(building or wire only)0 for cannot output into another building, 1 for can output(transfer items/power) to another building",
            "desc": "a description for how the building works and what the building script needs to do",
            "params":"(optional)exported variables configurable by the editor",
            "recipes": "for each recipe, takes id/name of items for its recipe and the table_type is at the end indicating where it can be formed in, time tells the processing time, and output is the number of items produced. null means cannot be craft",
            "health": "total base health (null=cannot be damaged)", 
            "item_dmg": "num of damage if shot as projectile or added on top of unit", 
            "item_elem": "gives material/item element which can be applied on enemy if shot as projectile",
            "dmg":"(optional): base damage of an offensive building",
            "tile": "a 2d array of the space",
            "dim": "dimensions of tile space"
    },
