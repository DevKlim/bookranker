    "jsonguide": {
        "basic_entry_guide": {
            "id": "Unique string ID used for filenames and references.",
            "name": "Display name.",
            "texture": "Path to icon/sprite (e.g. 'res://assets/icon.png').",
            "template": "Path to the base .tscn scene to instantiate.",
            "description": "Flavor text."
        },
        "grid_guide": {
            "width": "Width in tiles (int, default 1).",
            "height": "Height in tiles (int, default 1).",
            "layer": "Physical layer: 'building' (default) or 'wire'."
        },
        "logic_guide": {
            "has_input": "Bool. Can this accept items?",
            "has_output": "Bool. Can this eject items?",
            "health": "Float. Max HP.",
            "power_cost": "Float. Power consumption.",
            "power_gen": "Float. Power production.",
            "speed": "Float. Movement speed (Enemies).",
            "input_dir": "Int Enum (0=DOWN, 1=LEFT, 2=UP, 3=RIGHT).",
            "output_dir": "Int Enum (0=DOWN, 1=LEFT, 2=UP, 3=RIGHT)."
        },
        "recipe_guide": {
            "inputs": "Dictionary { 'item_id': count }.",
            "output": "String item_id of result.",
            "count": "Int amount produced.",
            "time": "Float seconds to craft."
        },
        "params_guide": {
            "info": "Injects values directly into script properties on the scene.",
            "syntax": "Key: 'NodeName:property' or 'Component/Child:property'.",
            "example": "'ShooterComponent:base_damage': 50.0"
        },
        "visuals_guide": {
            "texture": "Path to the spritesheet",
            "width": "Width of a single frame",
            "height": "Height of a single frame",
            "animations": {
                "anim_name": { 
                    "row": "Row index in sheet (0-based)", 
                    "count": "Number of frames", 
                    "speed": "FPS (default 5)",
                    "loop": "bool"
                }
            }
        },
        "modifiers_guide": {
            "speed_mult": "Multiplier (default 1.0). Affects movement speed of projectile, crafting/production speeds.",
            "cooldown": "Multiplier (default 1.0). Affects fire rate, mechanic activation speed.",
            "power_efficiency": "Multiplier (default 1.0). Multiplies power consumption.",
            "output_count": "Additive (default 0.0). Chance to duplicate output or add extra items.",
            "luck": "Additive (default 0.0). General purpose luck stat.",
            "xp_gain": "Multiplier (default 1.0).",
            "max_health_mult": "Multiplier (default 1.0). Buffs building HP.",
            "health_regen": "Additive (default 0.0). HP per second.",
            "armor": "Additive (default 0.0). Flat damage reduction.",
            "thorns": "Additive (default 0.0). Damage reflected.",
            "damage_mult": "Multiplier (default 1.0). Global damage.",
            "crit_chance": "Additive (default 0.0). 0.0 to 1.0.",
            "crit_damage": "Additive (default 1.5). Critical hit multiplier.",
            "area_size": "Multiplier (default 1.0). Projectile size/Blast radius.",
            "phys_boost": "Additive (default 0.0). Flat physical damage add. ",
            "magic_boost": "Additive (default 0.0). Flat magical damage add.",
            "armor_shred": "Additive (default 0.0). Armor penetration amount."
        }
